bar {
  id 0
  font pango:Iosevka Term Extended Medium 10
  position top
  height 28
  status_command ~/.config/sway/status.sh
  separator_symbol "│"
  status_edge_padding 8
  status_padding 2
  pango_markup disabled
  workspace_buttons no
    
  colors {
    background #11111bf2
    statusline #cdd6f4
    separator #45475aff
        
    binding_mode        #fab387 #313244 #cdd6f4
  }
}
