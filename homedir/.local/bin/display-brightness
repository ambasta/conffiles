#!/bin/bash
# Route brightness controls by active Sway output:
#   internal eDP/LVDS/DSI panels -> brightnessctl hardware backlight
#   external displays           -> wl-gammarelay-rs per-output brightness
set -uo pipefail

SERVICE=rs.wl-gammarelay
INTERFACE=rs.wl.gammarelay
UNIT=wl-gammarelay-rs.service
DEFAULT_STEP=${DISPLAY_BRIGHTNESS_STEP:-5}
MIN_EXTERNAL_PERCENT=${DISPLAY_BRIGHTNESS_MIN_PERCENT:-10}
INTERNAL_OUTPUT_REGEX=${DISPLAY_BRIGHTNESS_INTERNAL_REGEX:-'^(eDP|LVDS|DSI)(-|$)'}
VIRTUAL_OUTPUT_REGEX=${DISPLAY_BRIGHTNESS_VIRTUAL_REGEX:-'^(HEADLESS|VIRTUAL|WL)(-|$)'}
BACKLIGHT_DEVICE=${DISPLAY_BRIGHTNESS_BACKLIGHT_DEVICE:-}
LOCK_WAIT=${DISPLAY_BRIGHTNESS_LOCK_WAIT:-0.5}
STATE_DIR=${XDG_STATE_HOME:-$HOME/.local/state}/conffiles
STATE_FILE=$STATE_DIR/display-brightness
RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/$UID}
LOCK_FILE=$RUNTIME_DIR/display-brightness.lock

declare -a INTERNAL_OUTPUTS=()
declare -a EXTERNAL_OUTPUTS=()
declare -A OUTPUT_HDR=()
declare -A OUTPUT_ID=()

say() {
	printf '%s\n' "$*"
}

warn() {
	printf 'display-brightness: %s\n' "$*" >&2
}

die() {
	warn "$*"
	exit 1
}

valid_percent() {
	[[ $1 =~ ^[0-9]+([.][0-9]+)?$ ]] &&
		awk -v value="$1" 'BEGIN { exit !(value >= 0 && value <= 100) }'
}

valid_relay_value() {
	[[ $1 =~ ^[0-9]+([.][0-9]+)?$ ]] &&
		awk -v value="$1" -v minimum="$MIN_EXTERNAL_PERCENT" \
			'BEGIN { exit !(value >= 0 && value <= 1 && value * 100 >= minimum) }'
}

[[ -d $RUNTIME_DIR && -w $RUNTIME_DIR ]] || die "XDG_RUNTIME_DIR is unavailable"
lock_held=0

acquire_lock() {
	((lock_held)) && return 0
	exec 9>"$LOCK_FILE"
	if ! flock -w "$LOCK_WAIT" 9; then
		warn "brightness control is busy; skipped this key press"
		return 1
	fi
	lock_held=1
}

load_active_outputs() {
	local json rows name hdr make model serial identity
	INTERNAL_OUTPUTS=()
	EXTERNAL_OUTPUTS=()
	OUTPUT_HDR=()
	OUTPUT_ID=()

	json=$(swaymsg -t get_outputs -r 2>/dev/null) || return 1
	rows=$(jq -r '.[] | select(.active == true) |
		[.name, ((.hdr // false) | tostring), (.make // ""),
		 (.model // ""), (.serial // "")] | @tsv' <<<"$json") || return 1
	while IFS=$'\t' read -r name hdr make model serial; do
		[[ -n $name ]] || continue
		[[ $name =~ $VIRTUAL_OUTPUT_REGEX ]] && continue
		OUTPUT_HDR["$name"]=$hdr
		if [[ -n $serial && $serial != Unknown && $serial != unknown ]]; then
			identity="serial:$serial"
		else
			identity="connector:$name|$make|$model"
		fi
		OUTPUT_ID["$name"]=$identity
		if [[ $name =~ $INTERNAL_OUTPUT_REGEX ]]; then
			INTERNAL_OUTPUTS+=("$name")
		else
			EXTERNAL_OUTPUTS+=("$name")
		fi
	done <<<"$rows"
}

object_for_output() {
	local component
	component=$(sed 's/[^A-Za-z0-9_]/_/g' <<<"$1")
	printf '/outputs/%s\n' "$component"
}

relay_value() {
	local output=$1 object value
	object=$(object_for_output "$output")
	value=$(busctl --user get-property "$SERVICE" "$object" "$INTERFACE" Brightness 2>/dev/null) || return 1
	awk '$1 == "d" { print $2; found=1 } END { exit !found }' <<<"$value"
}

ensure_relay() {
	local output=$1 i
	relay_value "$output" >/dev/null 2>&1 && return 0
	if ! systemctl --user start "$UNIT"; then
		warn "failed to start $UNIT for $output"
		return 1
	fi
	for ((i = 0; i < 50; i++)); do
		relay_value "$output" >/dev/null 2>&1 && return 0
		sleep 0.1
	done
	warn "the relay did not publish active external output $output"
	return 1
}

detect_backlight() {
	local line name class _ devices=()
	if [[ -n $BACKLIGHT_DEVICE ]]; then
		brightnessctl -d "$BACKLIGHT_DEVICE" -m >/dev/null 2>&1 || {
			warn "brightnessctl device is unavailable: $BACKLIGHT_DEVICE"
			return 1
		}
		return 0
	fi
	while IFS=, read -r name class _; do
		[[ $class == backlight && -n $name ]] && devices+=("$name")
	done < <(brightnessctl --class=backlight --list --machine-readable 2>/dev/null)
	((${#devices[@]} > 0)) || {
		warn "brightnessctl found no hardware backlight"
		return 1
	}
	if ((${#devices[@]} == 1)); then
		BACKLIGHT_DEVICE=${devices[0]}
	elif printf '%s\n' "${devices[@]}" | grep -qx amdgpu_bl0; then
		BACKLIGHT_DEVICE=amdgpu_bl0
	else
		warn "multiple backlights found; set DISPLAY_BRIGHTNESS_BACKLIGHT_DEVICE"
		return 1
	fi
}

internal_value() {
	detect_backlight || return 1
	brightnessctl -d "$BACKLIGHT_DEVICE" -m 2>/dev/null |
		awk -F, 'NR == 1 { gsub(/%/, "", $4); print $4; found=1 } END { exit !found }'
}

save_external_value() {
	local output=$1 value=$2 identity current tmp
	identity=${OUTPUT_ID[$output]:-connector:$output}
	current='{"version":2,"outputs":{}}'
	if [[ -r $STATE_FILE ]] && jq -e '.version == 2 and (.outputs | type == "object")' \
		"$STATE_FILE" >/dev/null 2>&1; then
		current=$(<"$STATE_FILE")
	fi
	mkdir -p "$STATE_DIR" || return 1
	umask 077
	tmp=$(mktemp "$STATE_DIR/display-brightness.XXXXXX") || return 1
	if ! jq --arg identity "$identity" --arg connector "$output" \
		--argjson brightness "$value" \
		'.version = 2 | .outputs = (.outputs // {}) |
		 .outputs[$identity] = {brightness: $brightness, connector: $connector}' \
		<<<"$current" >"$tmp"; then
		rm -f "$tmp"
		return 1
	fi
	mv -f "$tmp" "$STATE_FILE"
}

saved_external_value() {
	local output=$1 identity value
	identity=${OUTPUT_ID[$output]:-connector:$output}
	[[ -r $STATE_FILE ]] || return 1
	if jq -e '.version == 2 and (.outputs | type == "object")' "$STATE_FILE" >/dev/null 2>&1; then
		value=$(jq -r --arg identity "$identity" \
			'.outputs[$identity].brightness // empty' "$STATE_FILE") || return 1
		[[ -n $value ]] || return 1
		printf '%s\n' "$value"
	else
		# Migrate the original one-value state lazily on the next successful write.
		IFS= read -r value <"$STATE_FILE" || return 1
		printf '%s\n' "$value"
	fi
}

apply_external_value() {
	local output=$1 percent=$2 object value applied
	percent=${percent%%%}
	valid_percent "$percent" || {
		warn "brightness must be between 0 and 100"
		return 1
	}
	awk -v value="$percent" -v minimum="$MIN_EXTERNAL_PERCENT" \
		'BEGIN { exit !(value >= minimum && value <= 100) }' || {
		warn "external brightness must be between $MIN_EXTERNAL_PERCENT and 100"
		return 1
	}
	object=$(object_for_output "$output")
	value=$(awk -v percent="$percent" 'BEGIN { printf "%.4f", percent / 100 }')
	if ! busctl --user set-property "$SERVICE" "$object" "$INTERFACE" Brightness d "$value"; then
		warn "failed to set relay brightness for $output"
		return 1
	fi
	applied=$(relay_value "$output") || {
		warn "cannot verify relay brightness for $output"
		return 1
	}
	awk -v expected="$value" -v actual="$applied" \
		'BEGIN { delta=expected-actual; if (delta<0) delta=-delta; exit !(delta<=0.0005) }' || {
		warn "relay brightness verification failed for $output"
		return 1
	}
	save_external_value "$output" "$applied" || {
		warn "failed to save brightness state for $output"
		return 1
	}
	say "$output: $(awk -v value="$applied" 'BEGIN { printf "%.0f", value * 100 }')% (wl-gammarelay-rs)"
}

change_external() {
	local output=$1 direction=$2 step=$3 current percent
	step=${step%%%}
	valid_percent "$step" || {
		warn "step must be between 0 and 100"
		return 1
	}
	current=$(relay_value "$output") || {
		warn "cannot read relay brightness for $output"
		return 1
	}
	percent=$(awk -v current="$current" -v step="$step" -v direction="$direction" \
		-v minimum="$MIN_EXTERNAL_PERCENT" 'BEGIN {
			value = current * 100 + (direction == "up" ? step : -step)
			if (value < minimum) value = minimum
			if (value > 100) value = 100
			printf "%.2f", value
		}')
	apply_external_value "$output" "$percent"
}

apply_internal() {
	local action=$1 amount=${2:-$DEFAULT_STEP} value
	amount=${amount%%%}
	valid_percent "$amount" || {
		warn "brightness must be between 0 and 100"
		return 1
	}
	detect_backlight || return 1
	case $action in
	up) brightnessctl -q -d "$BACKLIGHT_DEVICE" set "+${amount}%" ;;
	down) brightnessctl -q -d "$BACKLIGHT_DEVICE" set "${amount}%-" ;;
	set) brightnessctl -q -d "$BACKLIGHT_DEVICE" set "${amount}%" ;;
	reset) brightnessctl -q -d "$BACKLIGHT_DEVICE" set 100% ;;
	*)
		warn "unknown internal action: $action"
		return 1
		;;
	esac || {
		warn "brightnessctl failed for $BACKLIGHT_DEVICE"
		return 1
	}
	value=$(internal_value) || return 1
	say "LCD: ${value}% (brightnessctl $BACKLIGHT_DEVICE)"
}

join_parts() {
	local separator=$1 first=1 part
	shift
	for part in "$@"; do
		((first)) || printf '%s' "$separator"
		printf '%s' "$part"
		first=0
	done
}

show_status() {
	local target=$1 bar=${2:-} output value percent part errors=0 shown=0
	local -a parts=()
	load_active_outputs || die "cannot query active Sway outputs"

	if [[ $target == internal || $target == auto || $target == all ]]; then
		if [[ $target == internal || ${#INTERNAL_OUTPUTS[@]} -gt 0 ]]; then
			if detect_backlight && value=$(internal_value); then
				parts+=("LCD ${value}%")
				if [[ $bar != --bar ]]; then
				say "${INTERNAL_OUTPUTS[0]:-internal panel}: ${value}% (brightnessctl $BACKLIGHT_DEVICE)"
				fi
				shown=1
			else
				parts+=("LCD unavailable")
				errors=1
			fi
		fi
	fi

	if [[ $target == external || $target == auto || $target == all ]]; then
		for output in "${EXTERNAL_OUTPUTS[@]}"; do
			if value=$(relay_value "$output"); then
				percent=$(awk -v value="$value" 'BEGIN { printf "%.0f", value * 100 }')
				part="$output ${percent}%"
				[[ ${OUTPUT_HDR[$output]:-false} == true ]] && part+=" HDR"
				parts+=("$part")
				if [[ $bar != --bar ]]; then
					printf '%s: %s%% (wl-gammarelay-rs' "$output" "$percent"
					[[ ${OUTPUT_HDR[$output]:-false} == true ]] && printf ', HDR software dimming'
					printf ')\n'
				fi
				shown=1
			else
				parts+=("$output unavailable")
				errors=1
			fi
		done
	fi

	if ((shown == 0 && ${#parts[@]} == 0)); then
		[[ $bar == --bar ]] && say "DISPLAY unavailable" || warn "no controllable active display found"
		return 1
	fi
	if [[ $bar == --bar ]]; then
		printf 'DISP '
		join_parts ' · ' "${parts[@]}"
		printf '\n'
		return 0
	fi
	return "$errors"
}

restore_external() {
	local output value object errors=0
	load_active_outputs || return 1
	acquire_lock || return 0
	for output in "${EXTERNAL_OUTPUTS[@]}"; do
		value=$(saved_external_value "$output") || continue
		valid_relay_value "$value" || continue
		relay_value "$output" >/dev/null 2>&1 || continue
		object=$(object_for_output "$output")
		busctl --user set-property "$SERVICE" "$object" "$INTERFACE" Brightness d "$value" \
			>/dev/null || errors=1
	done
	return "$errors"
}

wait_restore() {
	local output i ready
	load_active_outputs || return 0
	((${#EXTERNAL_OUTPUTS[@]} > 0)) || return 0
	for ((i = 0; i < 50; i++)); do
		ready=1
		for output in "${EXTERNAL_OUTPUTS[@]}"; do
			relay_value "$output" >/dev/null 2>&1 || ready=0
		done
		if ((ready)); then
			restore_external || true
			return 0
		fi
		sleep 0.1
	done
	restore_external || true
	return 0
}

usage() {
	cat <<'EOF'
Usage:
  display-brightness [auto|all|internal|external] [up|down] [STEP]
  display-brightness [auto|all|internal|external] set PERCENT
  display-brightness [auto|all|internal|external] reset
  display-brightness [auto|all|internal|external] status [--bar]
  display-brightness restore|wait-restore

Auto/all adjusts every active display with the appropriate backend: hardware
brightnessctl for internal panels and wl-gammarelay-rs for external outputs.
Relative changes preserve each display's current independent level.
EOF
}

target=auto
if [[ ${1:-} =~ ^(auto|all|internal|external)$ ]]; then
	target=$1
	shift
fi
action=${1:-status}
shift || true
amount=${1:-$DEFAULT_STEP}

case $action in
status)
	show_status "$target" "${1:-}"
	exit
	;;
restore)
	restore_external
	exit
	;;
wait-restore)
	wait_restore
	exit
	;;
-h | --help | help)
	usage
	exit
	;;
up | down | set | reset) ;;
*)
	usage >&2
	die "unknown action: $action"
	;;
esac

load_active_outputs || die "cannot query active Sway outputs"
selected_internal=0
declare -a selected_external=()
case $target in
internal) selected_internal=1 ;;
external) selected_external=("${EXTERNAL_OUTPUTS[@]}") ;;
auto | all)
	((${#INTERNAL_OUTPUTS[@]} > 0)) && selected_internal=1
	selected_external=("${EXTERNAL_OUTPUTS[@]}")
	;;
esac

if ((selected_internal == 0 && ${#selected_external[@]} == 0)); then
	die "no controllable active display found"
fi

errors=0
declare -a ready_external=()
for output in "${selected_external[@]}"; do
	if ensure_relay "$output"; then
		ready_external+=("$output")
	else
		errors=1
	fi
done

acquire_lock || exit 0
if ((selected_internal)); then
	apply_internal "$action" "$amount" || errors=1
fi
for output in "${ready_external[@]}"; do
	case $action in
	up | down) change_external "$output" "$action" "$amount" || errors=1 ;;
	set) apply_external_value "$output" "$amount" || errors=1 ;;
	reset) apply_external_value "$output" 100 || errors=1 ;;
	esac
done
exit "$errors"
